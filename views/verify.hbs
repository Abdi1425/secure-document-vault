<!DOCTYPE html>
<html>
<head>
    <title>Verify Document - Secure Document Vault</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <style>
        .navbar { background-color: #2c3e50 !important; }
        .hash-match { color: green; font-weight: bold; }
        .hash-mismatch { color: red; font-weight: bold; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <a class="navbar-brand" href="/">🔐 Secure Document Vault</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="/documents/list">My Documents</a></li>
                <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h4>🔍 File Integrity Verification</h4>
                    </div>
                    <div class="card-body">
                        {{#if message}}
                            <div class="alert alert-danger">{{message}}</div>
                            <a href="/documents/list" class="btn btn-secondary">Back to Documents</a>
                        {{/if}}

                        {{#if document}}
                            <h5>Document: {{document.filename}}</h5>
                            <hr>
                            {{#if isIntegrityIntact}}
                                <div class="alert alert-success">
                                    <strong>✅ Integrity Verified!</strong> The file has not been modified since upload.
                                </div>
                            {{else}}
                                <div class="alert alert-danger">
                                    <strong>❌ Integrity Failed!</strong> The file has been modified or corrupted.
                                </div>
                            {{/if}}

                            <table class="table table-bordered mt-4">
                                <thead>
                                    <tr>
                                        <th>Algorithm</th>
                                        <th>Original Hash (Database)</th>
                                        <th>Current Hash (Computed)</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>MD5</td>
                                        <td><code>{{document.md5_hash}}</code></td>
                                        <td><code>{{currentHashes.md5}}</code></td>
                                        <td class="{{#if verification.md5}}hash-match{{else}}hash-mismatch{{/if}}">
                                            {{#if verification.md5}}MATCH{{else}}MISMATCH{{/if}}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>SHA1</td>
                                        <td><code>{{document.sha1_hash}}</code></td>
                                        <td><code>{{currentHashes.sha1}}</code></td>
                                        <td class="{{#if verification.sha1}}hash-match{{else}}hash-mismatch{{/if}}">
                                            {{#if verification.sha1}}MATCH{{else}}MISMATCH{{/if}}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>SHA256</td>
                                        <td><code>{{document.sha256_hash}}</code></td>
                                        <td><code>{{currentHashes.sha256}}</code></td>
                                        <td class="{{#if verification.sha256}}hash-match{{else}}hash-mismatch{{/if}}">
                                            {{#if verification.sha256}}MATCH{{else}}MISMATCH{{/if}}
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <a href="/documents/list" class="btn btn-primary mt-3">Back to Documents</a>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
