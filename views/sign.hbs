<!DOCTYPE html>
<html>
<head>
    <title>Sign Document - Secure Document Vault</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <style>
        .navbar { background-color: #2c3e50 !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <a class="navbar-brand" href="/">🔐 Secure Document Vault</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="/documents/list">My Documents</a></li>
                <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h4>✍️ Sign Document</h4>
                    </div>
                    <div class="card-body">
                        {{#if message}}
                            <div class="alert alert-info">{{message}}</div>
                            {{#if signature}}
                                <div class="alert alert-success mt-3">
                                    <h5>Signature Generated:</h5>
                                    <code>{{signature}}</code>
                                </div>
                            {{/if}}
                            <a href="/documents/list" class="btn btn-secondary mt-3">Back to Documents</a>
                            {{#unless signature}}
                                {{#if docId}}
                                    <a href="/profile" class="btn btn-primary mt-3">Go Generate Keys</a>
                                {{/if}}
                            {{/unless}}
                        {{else}}
                            <p>Are you sure you want to sign document #{{docId}} with your private key?</p>
                            <form action="/documents/sign/{{docId}}" method="POST">
                                <button type="submit" class="btn btn-warning">Sign Document</button>
                                <a href="/documents/list" class="btn btn-secondary">Cancel</a>
                            </form>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
