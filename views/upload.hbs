<!DOCTYPE html>
<html>
<head>
    <title>Upload Document - Secure Document Vault</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <style>
        .navbar { background-color: #2c3e50 !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <a class="navbar-brand" href="/">🔐 Secure Document Vault</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="/documents/list">My Documents</a></li>
                <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4>📤 Upload Document</h4>
                    </div>
                    <div class="card-body">
                        {{#if message}}
                            <div class="alert alert-info">{{message}}</div>
                        {{/if}}
                        
                        {{#if hashes}}
                            <div class="alert alert-success">
                                <h5>Document Hashes Computed:</h5>
                                <ul>
                                    <li><strong>MD5:</strong> {{hashes.md5}}</li>
                                    <li><strong>SHA1:</strong> {{hashes.sha1}}</li>
                                    <li><strong>SHA256:</strong> {{hashes.sha256}}</li>
                                </ul>
                                <a href="/documents/sign/{{docId}}" class="btn btn-warning mt-2">Sign Document Now</a>
                            </div>
                        {{else}}
                            <form action="/documents/upload" method="POST" enctype="multipart/form-data">
                                <div class="form-group">
                                    <label>Select Document to Upload</label>
                                    <input type="file" class="form-control-file" name="document" required>
                                </div>
                                <button type="submit" class="btn btn-primary">Upload and Compute Hashes</button>
                            </form>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
