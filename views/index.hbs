<!DOCTYPE html>
<html>
<head>
    <title>Secure Document Vault</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <style>
        .navbar { background-color: #2c3e50 !important; }
        .hero-section { background-color: #ecf0f1; padding: 50px 0; text-align: center; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <a class="navbar-brand" href="/">🔐 Secure Document Vault</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ml-auto">
                {{#if user_details}}
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                    <li class="nav-item"><a class="nav-link" href="/documents/list">My Documents</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout</a></li>
                {{else}}
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
                {{/if}}
            </ul>
        </div>
    </nav>

    <div class="hero-section mt-4">
        <div class="container">
            <h1>Welcome to Secure Document Vault</h1>
            <p class="lead">Upload, sign, and verify documents securely with Cryptographic proofs.</p>
            {{#if message}}
                <div class="alert alert-info">{{message}}</div>
            {{/if}}
            {{#if user_details}}
                <a href="/profile" class="btn btn-primary btn-lg mt-3">Go to Profile</a>
                <a href="/documents/upload" class="btn btn-success btn-lg mt-3">Upload Document</a>
            {{else}}
                <a href="/login" class="btn btn-primary btn-lg mt-3">Login to Start</a>
            {{/if}}
        </div>
    </div>
</body>
</html>
