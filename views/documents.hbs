<!DOCTYPE html>
<html>
<head>
    <title>My Documents - Secure Document Vault</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <style>
        .navbar { background-color: #2c3e50 !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <a class="navbar-brand" href="/">🔐 Secure Document Vault</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                <li class="nav-item active"><a class="nav-link" href="/documents/list">My Documents</a></li>
                <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-5">
        <h2>📋 My Documents</h2>
        {{#if message}}
            <div class="alert alert-info">{{message}}</div>
        {{/if}}

        {{#if documents.length}}
            <div class="table-responsive mt-4">
                <table class="table table-bordered table-striped">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Filename</th>
                            <th>Status</th>
                            <th>Uploaded At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each documents}}
                        <tr>
                            <td>{{this.id}}</td>
                            <td>{{this.filename}}</td>
                            <td>
                                {{#if this.has_signature}}
                                    <span class="badge badge-success">Signed</span>
                                {{else}}
                                    <span class="badge badge-warning">Not Signed</span>
                                {{/if}}
                            </td>
                            <td>{{this.uploaded_at}}</td>
                            <td>
                                <a href="/documents/verify/{{this.id}}" class="btn btn-sm btn-info">Verify Integrity</a>
                                {{#if this.has_signature}}
                                    <a href="/documents/verify-signature/{{this.id}}" class="btn btn-sm btn-success">Verify Signature</a>
                                {{else}}
                                    <a href="/documents/sign/{{this.id}}" class="btn btn-sm btn-warning">Sign</a>
                                {{/if}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        {{else}}
            <div class="alert alert-secondary mt-4">
                You haven't uploaded any documents yet. <a href="/documents/upload">Upload one now</a>.
            </div>
        {{/if}}
    </div>
</body>
</html>
