<!DOCTYPE html>
<html>
<head>
    <title>Verify Signature - Secure Document Vault</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
    <style>
        .navbar { background-color: #2c3e50 !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <a class="navbar-brand" href="/">🔐 Secure Document Vault</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="/documents/list">My Documents</a></li>
                <li class="nav-item"><a class="nav-link" href="/auth/logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h4>📜 Digital Signature Verification</h4>
                    </div>
                    <div class="card-body">
                        {{#if message}}
                            <div class="alert alert-danger">{{message}}</div>
                            <a href="/documents/list" class="btn btn-secondary">Back to Documents</a>
                        {{else}}
                            <h5>Document: {{document.filename}}</h5>
                            <p><strong>Signed by:</strong> {{signer}}</p>
                            <hr>
                            
                            {{#if isValid}}
                                <div class="alert alert-success">
                                    <strong>✅ Signature Valid!</strong> The document was indeed signed by {{signer}} and has not been tampered with.
                                </div>
                            {{else}}
                                <div class="alert alert-danger">
                                    <strong>❌ Signature Invalid!</strong> The document or signature may have been tampered with, or it was not signed by this key.
                                </div>
                            {{/if}}

                            <a href="/documents/list" class="btn btn-primary mt-3">Back to Documents</a>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
